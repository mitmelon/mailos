# ── Server ──────────────────────────────────────────────
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
JWT_SECRET=change_this_to_a_long_random_string
ENCRYPTION_KEY=32_char_minimum_secret_for_aes256

# ── API security ─────────────────────────────────────────
# Optional: bootstrap the single admin account from env instead of using the
# UI's first-run setup page. Only takes effect if no account exists yet.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Comma-separated list of valid API keys for EXTERNAL/programmatic clients.
# The browser UI uses username/password + session cookie instead (always
# enforced, independent of this setting).
API_KEYS=
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
# Stricter limit for routes that send real email or spend real AI tokens
# (/connect-email, /sync, /ingest, /negotiations, /ask).
RATE_LIMIT_SENSITIVE_MAX=20

# ── Qwen (the only AI provider MailOS uses) ─────────────
# Get a key from the Alibaba Cloud Model Studio / DashScope console:
# https://bailian.console.alibabacloud.com/  ->  API-KEY management
QWEN_API_KEY=your_qwen_dashscope_api_key
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
QWEN_EMBEDDING_MODEL=text-embedding-v3

# ── Storage ───────────────────────────────────────────────
# Zero-setup by default: embedded NoSQL storage (no server process). Set
# MONGODB_URI only if you specifically need multi-server horizontal scaling.
MONGODB_URI=

# Zero-setup by default: in-process event bus. Set REDIS_URL to switch every
# pipeline stage to real BullMQ-backed Redis queues.
REDIS_URL=

# ── Decision thresholds ─────────────────────────────────
AUTO_REPLY_CONFIDENCE_THRESHOLD=0.85
AUTO_ARCHIVE_CONFIDENCE_THRESHOLD=0.9

# ── Autonomous negotiation (Track 3: Agent Society) ─────
# Hard ceiling on back-and-forth exchanges before forced escalation.
NEGOTIATION_MAX_ROUNDS=10
# Autonomous replies are only ever sent within these bounds — anything outside
# them escalates to the human instead of sending. Hard stops, not suggestions.
NEGOTIATION_MAX_DISCOUNT_PERCENT=15
NEGOTIATION_APPROVAL_ABOVE=
NEGOTIATION_MIN_CONFIDENCE=0.7
# Global fallback webhook for escalations if a mailbox doesn't set its own.
# Point this at a Telegram bot, Slack incoming webhook, Discord webhook, or
# any endpoint that accepts a JSON POST.
NEGOTIATION_WEBHOOK_URL=

# ── Updates ──────────────────────────────────────────────
# Set to your own fork/repo (e.g. "yourname/mailos") to enable the
# in-app "update available" check against GitHub releases.
GITHUB_REPO=
